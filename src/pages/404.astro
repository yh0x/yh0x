---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 - 페이지를 찾을 수 없습니다" description="요청한 페이지를 찾을 수 없습니다.">
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center">
    <p class="text-8xl font-bold text-neutral-200 dark:text-neutral-800 mb-4">404</p>
    <h1 class="text-2xl font-semibold text-neutral-900 dark:text-neutral-100 mb-2">
      페이지를 찾을 수 없습니다
    </h1>
    <p class="text-neutral-600 dark:text-neutral-400 mb-8">
      요청하신 페이지가 존재하지 않거나 이동되었습니다.
    </p>
    <a
      href="/"
      class="px-6 py-3 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 transition-colors font-medium"
    >
      홈으로 돌아가기
    </a>
  </div>
</BaseLayout>
