---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by year
const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title="Blog" description="개발, AI, 도구에 관한 기술 포스팅">
  <div class="animate-fade-up">
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-2">Blog</h1>
      <p class="text-neutral-600 dark:text-neutral-400">개발, AI, 도구에 관한 이야기들</p>
    </div>

    <div class="space-y-12">
      {years.map((year) => (
        <section>
          <h2 class="text-sm font-semibold text-neutral-400 dark:text-neutral-600 mb-4 pb-2 border-b border-neutral-100 dark:border-neutral-900">
            {year}
          </h2>
          <div class="space-y-1">
            {postsByYear[year].map((post) => (
              <a
                href={`/blog/${post.id.replace(/\.mdx?$/, "")}`}
                class="group flex items-center justify-between gap-4 py-3 px-3 -mx-3 rounded-lg hover:bg-neutral-50 dark:hover:bg-neutral-900 transition-colors"
              >
                <div class="flex items-center gap-3 min-w-0">
                  <span class="w-1.5 h-1.5 rounded-full bg-neutral-300 dark:bg-neutral-700 flex-shrink-0 group-hover:bg-indigo-500 transition-colors"></span>
                  <span class="font-medium text-neutral-800 dark:text-neutral-200 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors truncate">
                    {post.data.title}
                  </span>
                </div>
                <time class="text-sm text-neutral-400 dark:text-neutral-600 flex-shrink-0">
                  <FormattedDate date={post.data.date} />
                </time>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-neutral-500 dark:text-neutral-500 text-center py-16">아직 포스팅이 없습니다.</p>
    )}
  </div>
</BaseLayout>
