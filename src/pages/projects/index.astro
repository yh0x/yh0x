---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Projects" description="사이드 프로젝트 및 개발 프로젝트 모음">
  <div class="animate-fade-up">
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-2">Projects</h1>
      <p class="text-neutral-600 dark:text-neutral-400">사이드 프로젝트와 개인 작업물들</p>
    </div>

    <div class="grid gap-5">
      {projects.map((project) => (
        <a
          href={`/projects/${project.id.replace(/\.mdx?$/, "")}`}
          class="group block p-6 rounded-xl border border-neutral-200 dark:border-neutral-800 hover:border-neutral-300 dark:hover:border-neutral-700 hover:bg-neutral-50 dark:hover:bg-neutral-900 transition-all"
        >
          <div class="flex items-start justify-between gap-4 mb-3">
            <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
              {project.data.title}
            </h2>
            <div class="flex items-center gap-2 flex-shrink-0">
              {project.data.github && (
                <span class="text-xs px-2 py-1 rounded-md border border-neutral-200 dark:border-neutral-700 text-neutral-500 dark:text-neutral-500">
                  GitHub
                </span>
              )}
              {project.data.demo && (
                <span class="text-xs px-2 py-1 rounded-md border border-neutral-200 dark:border-neutral-700 text-neutral-500 dark:text-neutral-500">
                  Demo
                </span>
              )}
            </div>
          </div>
          <p class="text-neutral-600 dark:text-neutral-400 text-sm mb-4 leading-relaxed">
            {project.data.description}
          </p>
          <div class="flex flex-wrap gap-1.5">
            {project.data.tags.map((tag) => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>

    {projects.length === 0 && (
      <p class="text-neutral-500 dark:text-neutral-500 text-center py-16">아직 프로젝트가 없습니다.</p>
    )}
  </div>
</BaseLayout>
